# AGENTOR — Environment Variables
# Copy to .env and fill in real values before running docker-compose.
# .env is in .gitignore — never commit real credentials.

# ── PostgreSQL + pgvector ───────────────────────────────────────
POSTGRES_DB=agentor_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5433

# ── Redis ───────────────────────────────────────────────────────
REDIS_PORT=6379

# ── MinIO (S3-compatible object storage) ───────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Go Daemon ───────────────────────────────────────────────────
DAEMON_HTTP_PORT=8080
GRPC_PORT=50051
LOG_LEVEL=info
COUNCIL_TIMEOUT_SECONDS=60

# ── Security ────────────────────────────────────────────────────
# Set to "true" ONLY in local dev to disable mTLS (ADR-0001 constraint).
AGENTOR_INSECURE=false

# ── Observability ───────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
SENTRY_DSN=

# ── AI / LLM ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── MinIO as S3 (for SDK clients) ──────────────────────────────
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
AWS_ENDPOINT_URL=http://localhost:${MINIO_PORT:-9000}
AWS_REGION=us-east-1
