# ZIOM — Environment Variables
# Copy to .env and fill in real values before running docker-compose.
# .env is in .gitignore — never commit real credentials.

# ── PostgreSQL + pgvector ───────────────────────────────────────
POSTGRES_DB=ziom_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5433
# Password for the limited app role (migrations/002_ziom_app_role.sql).
# Supplied to the migration via PGOPTIONS="-c app.ziom_app_password=$ZIOM_APP_DB_PASSWORD".
ZIOM_APP_DB_PASSWORD=change_me_in_production

# ── Redis ───────────────────────────────────────────────────────
REDIS_PORT=6379

# ── MinIO (S3-compatible object storage) ───────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_production
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Go Daemon ───────────────────────────────────────────────────
DAEMON_HTTP_PORT=8080
GRPC_PORT=50051
LOG_LEVEL=info
COUNCIL_TIMEOUT_SECONDS=60

# ── Security ────────────────────────────────────────────────────
# Set to "true" ONLY in local dev to disable mTLS (ADR-0001 constraint).
ZIOM_INSECURE=false
ZIOM_DEFAULT_PROVIDER=groq   # fallback provider when tier system is bypassed

# ── Observability ───────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
SENTRY_DSN=

# ── AI / LLM — MODEL ROUTING (ADR-0012 + OpenRouter hub) ───────
# ── TIER CRITICAL ──────────────────────────────
ANTHROPIC_API_KEY=        # claude-opus-4-8 + sonnet-4-6

# ── TIER STANDARD FALLBACK ─────────────────────
GEMINI_API_KEY=           # gemini-3.5-flash

# ── TIER OPENROUTER (Chinese frontier coders + GPT-5.5) ─────────
OPENROUTER_API_KEY=       # hub: access to 300+ models
OPENROUTER_MODEL=deepseek/deepseek-v4-pro   # used when OPENROUTER_ROUTING=single
OPENROUTER_ROUTING=auto   # auto = per-agent-role routing | single = OPENROUTER_MODEL for all

# ── EMERGENCY ──────────────────────────────────
GROQ_API_KEY=             # last-resort fallback

# ── OpenAI Codex (opt-in only) ─────────────────
OPENAI_API_KEY=           # gpt-5.5 direct (not in default provider order)

# ── TIER SYSTEM ────────────────────────────────
ZIOM_PROVIDER_ORDER=anthropic,gemini,openrouter,groq
ZIOM_LLM_MODEL_CRITICAL=claude-opus-4-8
ZIOM_MAX_CLAIM_ATTEMPTS=3
ZIOM_MAX_COUNCIL_ROUNDS=2

# ── MinIO as S3 (for SDK clients) ──────────────────────────────
AWS_ACCESS_KEY_ID=${MINIO_ROOT_USER}
AWS_SECRET_ACCESS_KEY=${MINIO_ROOT_PASSWORD}
AWS_ENDPOINT_URL=http://localhost:${MINIO_PORT:-9000}
AWS_REGION=us-east-1
